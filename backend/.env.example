# Database — PostgreSQL (default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/linguist_guardian

# For SQLite (lightweight local dev, no PostgreSQL needed):
# DATABASE_URL=sqlite+aiosqlite:///./linguist_guardian.db

# OpenAI — leave empty to use mock mode
OPENAI_API_KEY=

# Whisper mode: "mock" | "api"
WHISPER_MODE=mock

# Server
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
